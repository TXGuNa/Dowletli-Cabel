{
  // Cloudflare Workers — serve the built Vite SPA as static assets.
  // `build.command` runs `npm run build` before deploy so ./dist exists.
  "name": "dowletli",
  "compatibility_date": "2024-11-01",
  "build": {
    "command": "npm run build"
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
